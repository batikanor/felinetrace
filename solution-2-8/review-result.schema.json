{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TraceReviewResult",
  "type": "object",
  "required": ["task_id", "verdict", "amount_eur", "source_ids", "patch", "approval"],
  "properties": {
    "task_id": { "type": "string" },
    "verdict": {
      "type": "string",
      "enum": ["supported", "needs_follow_up", "control_exception", "draft_ready"]
    },
    "amount_eur": { "type": "number" },
    "source_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "patch": {
      "type": "object",
      "required": ["target", "text"],
      "properties": {
        "target": { "type": "string" },
        "text": { "type": "string" }
      },
      "additionalProperties": false
    },
    "approval": { "const": "required" }
  },
  "additionalProperties": false
}
